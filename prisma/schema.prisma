// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id
  username  String    @unique
  password  String
  name      String
  lastName  String
  email     String    @unique
  tasks     Task[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Task {
  id          String     @id
  name        String
  description String
  status      TaskStatus
  createdAt   DateTime   @default(now())
  deadline    DateTime
  userId      String
  user        User       @relation(fields: [userId], references: [id])
}

enum TaskStatus {
  in_process
  completed
  cancelled
}
